{
  "name": "golewood-ru",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  },
  "imports": {
    "#shared/*": "./shared/*"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify": "npm run lint && npm run test:run && npm run build",
    "verify:all": "npm run verify && npm run test:e2e",
    "check:prod": "node --experimental-strip-types scripts/check-prod-env.ts --prod",
    "preflight:prod": "NODE_ENV=production npm run check:prod",
    "launch:status": "bash scripts/launch-status.sh",
    "launch:verify": "npm run verify:all",
    "github:setup": "bash scripts/github-setup.sh",
    "secrets:prod": "bash scripts/generate-prod-secrets.sh",
    "setup:prod-env": "bash scripts/setup-prod-env.sh",
    "prod:up": "bash scripts/prod-up.sh --migrate",
    "smoke:prod": "bash scripts/post-deploy-smoke.sh",
    "bootstrap": "bash scripts/bootstrap-dev.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --experimental-strip-types scripts/seed.ts",
    "db:seed:cities": "node --experimental-strip-types scripts/seed-cities.ts",
    "db:seed:reset": "SEED_RESET=1 node --experimental-strip-types scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "icons:generate": "node --experimental-strip-types scripts/generate-pwa-icons.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "^10.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "@tiptap/vue-3": "^3.23.5",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.0",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.14.0",
    "jose": "^6.2.3",
    "maplibre-gl": "^5.24.0",
    "meilisearch": "^0.58.0",
    "nuxt": "^4.4.6",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.52.0",
    "@vue/test-utils": "^2.4.10",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.6"
  }
}
