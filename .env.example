# Database
NUXT_DATABASE_URL=postgresql://golewood:golewood@localhost:5433/golewood

# Redis
NUXT_REDIS_URL=redis://localhost:6379

# Meilisearch (production: required master key, min 16 chars — see deploy/.env.production.example)
NUXT_MEILI_HOST=http://localhost:7700
NUXT_MEILI_API_KEY=

# Auth
NUXT_JWT_SECRET=change-me-in-production-use-long-random-string
NUXT_AUTH_DEV_CODE=0000

# Local uploads (dev). Leave empty for default `.data/uploads`
NUXT_UPLOADS_DIR=

# SMS.ru — not used (phone login and booking SMS are disabled by default).
NUXT_SMS_RU_API_ID=

# Phone OTP via SMS — leave off (do not enable without SMS.ru budget).
# NUXT_PUBLIC_SMS_AUTH_ENABLED=true

# Email OTP — on by default in nuxt.config; override if needed.
# NUXT_PUBLIC_EMAIL_AUTH_ENABLED=true

# Booking/status SMS — leave off; use email (NUXT_SMTP_URL) and/or MAX bot.
# NUXT_SMS_NOTIFICATIONS_ENABLED=true

# MAX messenger bot (host notifications + Bridge mini-app — off by default)
# NUXT_MAX_BOT_TOKEN=
# NUXT_MAX_WEBHOOK_SECRET=
# NUXT_PUBLIC_MAX_BOT_USERNAME=
# NUXT_MAX_NOTIFICATIONS_ENABLED=true
# Mini-app URL in business.max.ru: https://<your-domain>/max

# Email (leave empty to log to console in dev; set SMTP webhook URL for production)
NUXT_SMTP_URL=
# Support inbox (UI + contact form delivery). SMTP may use a different mailbox (SMTP_USER).
NUXT_PUBLIC_SUPPORT_EMAIL=golewood@internet.ru
NUXT_SUPPORT_EMAIL=golewood@internet.ru

# Legal requisites on /legal/requisites (optional overrides)
# NUXT_PUBLIC_OPERATOR_LEGAL_NAME=
# NUXT_PUBLIC_OPERATOR_INN=
# NUXT_PUBLIC_OPERATOR_KPP=
# NUXT_PUBLIC_OPERATOR_OGRN=
# NUXT_PUBLIC_OPERATOR_LEGAL_ADDRESS=

# S3-compatible storage (leave empty for local uploads)
NUXT_S3_BUCKET=
NUXT_S3_REGION=ru-central1
NUXT_S3_ACCESS_KEY=
NUXT_S3_SECRET_KEY=
NUXT_S3_ENDPOINT=
NUXT_S3_PUBLIC_URL=

# YooKassa (leave empty for mock payments in dev)
# Test shop: create at https://yookassa.ru — use test shop_id/secret; webhook: {SITE_URL}/api/payments/yookassa/webhook
NUXT_YOOKASSA_SHOP_ID=
NUXT_YOOKASSA_SECRET_KEY=
# Dev only: instant host payout profile without YooKassa marketplace API
NUXT_YOOKASSA_MARKETPLACE_MOCK=true
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: fallback Open Graph image path (e.g. /og-cover.png, 1200×630)
# NUXT_PUBLIC_DEFAULT_OG_IMAGE=/icon-512.png

# CORS (defaults to NUXT_PUBLIC_SITE_URL)
NUXT_CORS_ORIGIN=

# Rate limiting (optional overrides)
NUXT_RATE_LIMIT_MAX=
NUXT_RATE_LIMIT_WINDOW_SEC=

# Cron (iCal sync + promotion Meili fields every 6h on node-server)
# NUXT_CALENDAR_SYNC_CRON_ENABLED=true
# NUXT_PROMOTION_INDEX_CRON_ENABLED=true
NUXT_CRON_SECRET=

# Production checklist: NODE_ENV=production npm run check:prod

# OAuth (leave empty for mock login in dev)
NUXT_OAUTH_YANDEX_CLIENT_ID=
NUXT_OAUTH_YANDEX_CLIENT_SECRET=
NUXT_OAUTH_VK_CLIENT_ID=
NUXT_OAUTH_VK_CLIENT_SECRET=
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
