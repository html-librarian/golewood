# Copy to project root as `.env` on the server:
#   cp deploy/.env.production.example .env
# Generate secrets: openssl rand -hex 32

# --- Docker infra (used by docker-compose.prod.yml) ---
POSTGRES_USER=golewood
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=golewood

# Set true only for first boot if you want migrate inside the app container
RUN_DB_MIGRATE_ON_START=false

# --- App (Nuxt runtime) ---
NUXT_DATABASE_URL=postgresql://golewood:CHANGE_ME_LONG_RANDOM@postgres:5432/golewood
NUXT_REDIS_URL=redis://redis:6379
NUXT_MEILI_HOST=http://meilisearch:7700
NUXT_MEILI_API_KEY=CHANGE_ME_MEILI_MASTER_KEY_MIN_16_CHARS

NUXT_JWT_SECRET=CHANGE_ME_JWT_AT_LEAST_32_CHARS
NUXT_PUBLIC_SITE_URL=https://golewood.ru

# Legal pages (/legal/requisites) — replace demo values before launch
# NUXT_PUBLIC_OPERATOR_LEGAL_NAME=ООО «Ваша компания»
# Quote numeric IDs so .env parsers keep them as strings (optional — app coerces numbers too)
# NUXT_PUBLIC_OPERATOR_INN="7710140679"
# NUXT_PUBLIC_OPERATOR_KPP="771301001"
# NUXT_PUBLIC_OPERATOR_OGRN="1027739642281"
# NUXT_PUBLIC_OPERATOR_LEGAL_ADDRESS=
NUXT_CORS_ORIGIN=https://golewood.ru

# Never set in production (ignored by app if set, but check:prod will fail)
# NUXT_AUTH_DEV_CODE=

# Never true on production host
NUXT_YOOKASSA_MARKETPLACE_MOCK=false

NUXT_CRON_SECRET=CHANGE_ME_CRON_SECRET
NUXT_CALENDAR_SYNC_CRON_ENABLED=true
NUXT_PROMOTION_INDEX_CRON_ENABLED=true

# Auth (email on by default; add OAuth for convenience)
NUXT_PUBLIC_EMAIL_AUTH_ENABLED=true
NUXT_SMTP_URL=http://mail-relay:8787/send
NUXT_PUBLIC_SUPPORT_EMAIL=support@golewood.ru
NUXT_SUPPORT_EMAIL=support@golewood.ru

# mail-relay service (Mail.ru / internet.ru / bk.ru — smtp.mail.ru)
# Default 465 SSL; if VPS blocks 465 use SMTP_PORT=587 and SMTP_SECURE=false
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=golewood@internet.ru
SMTP_PASS=CHANGE_ME_MAILRU_APP_PASSWORD
SMTP_FROM=golewood@internet.ru

# NUXT_PUBLIC_SMS_AUTH_ENABLED=true
# NUXT_SMS_RU_API_ID=
# NUXT_SMS_NOTIFICATIONS_ENABLED=true

NUXT_OAUTH_YANDEX_CLIENT_ID=
NUXT_OAUTH_YANDEX_CLIENT_SECRET=
NUXT_OAUTH_VK_CLIENT_ID=
NUXT_OAUTH_VK_CLIENT_SECRET=
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Payments (live or test shop; enable «Сплитование платежей» in YooKassa)
NUXT_YOOKASSA_SHOP_ID=
NUXT_YOOKASSA_SECRET_KEY=
NUXT_YOOKASSA_MARKETPLACE_MOCK=false
# After deploy: hosts → /host/payout; admin → /admin/host-payouts (paste recipient account_id)

# Media (required for production — uploads survive redeploy)
NUXT_S3_BUCKET=
NUXT_S3_REGION=ru-central1
NUXT_S3_ACCESS_KEY=
NUXT_S3_SECRET_KEY=
NUXT_S3_ENDPOINT=
NUXT_S3_PUBLIC_URL=

# MAX (optional)
# NUXT_MAX_BOT_TOKEN=
# NUXT_MAX_WEBHOOK_SECRET=
# NUXT_PUBLIC_MAX_BOT_USERNAME=
# NUXT_MAX_NOTIFICATIONS_ENABLED=true
